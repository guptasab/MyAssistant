# Ollie configuration — copy to project root as `.env`
# Ollie is your one-stop life assistant: family + personal + work.

# ---- Core ----
ANTHROPIC_API_KEY=sk-ant-...
RAM_OWNER_NAME=Sagupta
RAM_TIMEZONE=America/Los_Angeles
RAM_DATA_DIR=./data

# Model selection. Opus for hard reasoning, Haiku for fast classification.
RAM_MODEL_MAIN=claude-opus-4-7
RAM_MODEL_FAST=claude-haiku-4-5-20251001

# ---- Ollie behavior ----
OLLIE_BRIEFING_TIME=07:00              # morning briefing (HH:MM, local)
OLLIE_EVENING_BRIEF_TIME=20:30         # tomorrow look-ahead
OLLIE_POLL_INTERVAL_MINUTES=15         # inbox / school scan cadence
OLLIE_DEFAULT_CONTEXT=personal         # work | personal | family

# ---- Channels ----
DISCORD_BOT_TOKEN=
DISCORD_OWNER_USER_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Twilio — Ollie's signature SMS surface (+ WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+15551234567
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Mobile PWA / HTTP API. Twilio webhook: POST /twilio/sms
RAM_HTTP_HOST=0.0.0.0
RAM_HTTP_PORT=8765
RAM_HTTP_TOKEN=change-me-to-a-long-random-string

# ---- Skills ----
# Search
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=

# Maps / traffic / nearby
GOOGLE_MAPS_API_KEY=

# Google (Gmail + Calendar). One OAuth client covers both.
# Scopes requested: calendar, gmail.readonly, gmail.modify.
GOOGLE_OAUTH_CLIENT_SECRETS=./config/google_oauth.json

# Alexa / smart home (via Home Assistant proxy)
HA_BASE_URL=
HA_TOKEN=

# Work integrations
SLACK_BOT_TOKEN=
SLACK_USER_ID=
NOTION_API_KEY=
LINEAR_API_KEY=
GITHUB_TOKEN=

# Finance (optional — for live bank/cc sync)
PLAID_CLIENT_ID=
PLAID_SECRET=

# Voice
OPENAI_API_KEY=          # for Whisper STT (optional)
ELEVENLABS_API_KEY=      # for premium TTS (optional)
ELEVENLABS_VOICE_ID=
